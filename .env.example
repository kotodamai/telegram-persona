# OpenAI-compatible API configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here

# Model selection
TIER1_MODEL=gpt-5.4-mini
TIER2_MODEL=gpt-5.4

# Concurrency for Tier-1 batch annotation
CONCURRENCY=5

# API timeout per request in seconds (default: 180)
# API_TIMEOUT=180
# Max retries per API call (default: 3)
# API_MAX_RETRIES=3
